# Server Configuration
# PORT is hardcoded to 3000 in server.ts
# VITE_PORT is hardcoded to 3000 in vite.config.ts
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.far8vuq.mongodb.net/your-database?appName=Cluster0

# Application Settings
APP_NAME=TutorSphere
APP_VERSION=1.0.0

# Security (Required for production)
# JWT_SECRET=your-jwt-secret-here
# SESSION_SECRET=your-session-secret-here

# External Services (Optional)
# GEMINI_API_KEY=your-gemini-api-key-here
# EMAIL_SERVICE_API_KEY=your-email-service-key-here
