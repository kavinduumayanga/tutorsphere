# Server Configuration
NODE_ENV=development
# Optional locally. Azure App Service injects PORT automatically.
PORT=3000
DOTENV_CONFIG_SILENT=true
DEBUG=false

# Database Configuration
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.far8vuq.mongodb.net/your-database?appName=Cluster0

# Application Settings
APP_NAME=TutorSphere
APP_VERSION=1.0.0

# Security (Required for production)
# Use strong unique values in production.
JWT_SECRET=replace-with-strong-random-jwt-secret
SESSION_SECRET=replace-with-strong-random-session-secret
# Comma-separated browser origins allowed to call the API with credentials.
# Required in production.
ALLOWED_ORIGINS=https://www.tutorsphere.me,https://tutorsphere.me

# External Services (Optional)
# GEMINI_API_KEY=your-gemini-api-key-here
# EMAIL_SERVICE_API_KEY=your-email-service-key-here

# Password Reset Email (Required for OTP-based forgot password flow)
# Use Gmail App Password, not your regular Gmail password.
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-16-char-gmail-app-password
EMAIL_FROM=your-gmail-address@gmail.com
OTP_EXPIRY_MINUTES=10

# Password Reset Flow
PASSWORD_RESET_FRONTEND_URL=https://www.tutorsphere.me/reset-password
# For local development you can use:
# PASSWORD_RESET_FRONTEND_URL=http://localhost:3000/reset-password
# Clamped between 15 and 30 minutes
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=20

# Azure OpenAI (Required for Quiz Chatbot AI)
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=your-chat-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure Blob Storage (Required for file uploads)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account-name;AccountKey=your-account-key;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_PROFILE_IMAGES=profile-images
AZURE_BLOB_CONTAINER_COURSE_THUMBNAILS=course-thumbnails
AZURE_BLOB_CONTAINER_VIDEOS=videos
AZURE_BLOB_CONTAINER_RESOURCES=resources
AZURE_BLOB_CONTAINER_RECORDED_LESSONS=recorded-lessons
AZURE_BLOB_CONTAINER_TUTOR_CERTIFICATES=tutor-certificates

# Azure Blob upload performance tuning (Optional)
# Used for stream-based video uploads.
AZURE_BLOB_LARGE_UPLOAD_BLOCK_SIZE_MB=8
AZURE_BLOB_LARGE_UPLOAD_CONCURRENCY=5

# Image optimization tuning for avatar/thumbnail uploads (Optional)
AZURE_IMAGE_AVATAR_MAX_WIDTH=512
AZURE_IMAGE_AVATAR_MAX_HEIGHT=512
AZURE_IMAGE_THUMBNAIL_MAX_WIDTH=1280
AZURE_IMAGE_THUMBNAIL_MAX_HEIGHT=720
AZURE_IMAGE_QUALITY=82
